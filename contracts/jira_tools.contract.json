      "input_schema": {
        "properties": {
          "issue_key": {
            "type": "string",
            "description": "Issue key such as JRASERVER-79286"
          }
        },
        "required": ["issue_key"]
      },
      "output_schema": {
        "properties": {
          "key": {"type": "string"},
          "status": {"type": "string"},
          "updated": {"type": "string"}
        },
        "required": ["key", "status", "updated"]
      }
    },
    {
