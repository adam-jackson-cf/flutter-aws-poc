{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flutter-aws-poc/contracts/schemas/workflow-contract.schema.json",
  "title": "Workflow Contract",
  "type": "object",
  "required": [
    "kind",
    "metadata",
    "governance",
    "steps",
    "idempotency",
    "compensation"
  ],
  "properties": {
    "kind": {
      "const": "WorkflowContract"
    },
    "metadata": {
      "type": "object",
      "required": ["workflow_id", "version"],
      "properties": {
        "workflow_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      },
      "additionalProperties": false
    },
    "governance": {
      "type": "object",
      "required": ["risk_tier"],
      "properties": {
        "risk_tier": {
          "type": "string",
          "enum": ["R2", "R3"]
        }
      },
      "additionalProperties": false
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["step_id", "mode"],
        "properties": {
          "step_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "mode": {
            "type": "string",
            "enum": ["automated", "human_review", "compensation"]
          }
        },
        "additionalProperties": false
      }
    },
    "idempotency": {
      "type": "object",
      "required": ["key_path"],
      "properties": {
        "key_path": {
          "type": "string",
          "minLength": 2
        }
      },
      "additionalProperties": false
    },
    "compensation": {
      "type": "object",
      "required": ["required"],
      "properties": {
        "required": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
