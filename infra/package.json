{
  "name": "flutter-agentcore-poc-infra",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -w -p tsconfig.json",
    "cdk:synth": "cdk synth",
    "cdk:diff": "cdk diff",
    "cdk:deploy": "cdk deploy --require-approval never",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "npm run lint"
  },
  "dependencies": {
    "@aws-cdk/aws-bedrock-agentcore-alpha": "2.240.0-alpha.0",
    "aws-cdk-lib": "2.240.0",
    "constructs": "10.5.1",
    "source-map-support": "0.5.21"
  },
  "devDependencies": {
    "@types/node": "24.3.0",
    "aws-cdk": "2.1108.0",
    "ts-node": "10.9.2",
    "typescript": "5.9.2"
  }
}
