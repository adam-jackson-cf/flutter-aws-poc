{
  "name": "flutter-design-contract-policy",
  "version": "1.0.0",
  "rules": [
    {
      "rule_id": "R1-CAPABILITY-DEFINITION-SCHEMA",
      "tier": "R1",
      "title": "Capability Definitions must match the governed schema",
      "check_name": "r1_capability_definition_schema"
    },
    {
      "rule_id": "R1-SAFETY-ENVELOPE-SCHEMA",
      "tier": "R1",
      "title": "Safety Envelopes must match the governed schema",
      "check_name": "r1_safety_envelope_schema"
    },
    {
      "rule_id": "R1-IDENTITY-CONTEXT-CONTRACT",
      "tier": "R1",
      "title": "Capabilities must declare gateway routing and identity context requirements",
      "check_name": "r1_identity_context_contract"
    },
    {
      "rule_id": "R2-EVALUATION-PACK-SCHEMA",
      "tier": "R2",
      "title": "Evaluation packs must match the governed schema",
      "check_name": "r2_evaluation_pack_schema"
    },
    {
      "rule_id": "R2-PUBLISH-READYNESS",
      "tier": "R2",
      "title": "Review and Published capabilities must satisfy publish gate invariants",
      "check_name": "r2_publish_readiness"
    },
    {
      "rule_id": "R3-WORKFLOW-CONTRACT-SCHEMA",
      "tier": "R3",
      "title": "Workflow Contracts must match the governed schema",
      "check_name": "r3_workflow_contract_schema"
    },
    {
      "rule_id": "R3-PROCESS-CONTRACT-REQUIRED",
      "tier": "R3",
      "title": "R2 and R3 capabilities must reference a matching Workflow Contract",
      "check_name": "r3_process_contract_required"
    }
  ]
}
